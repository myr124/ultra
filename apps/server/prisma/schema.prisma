generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

model User {
  id          String         @id @default(cuid())
  email       String         @unique
  name        String?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  preferences UserPreference?
  tasks       Task[]
  snapshots   EnergySnapshot[]
}

model UserPreference {
  id               String   @id @default(cuid())
  userId           String   @unique
  chronotype       String?
  wakeTime         String?
  notificationsOn  Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Task {
  id                 String   @id @default(cuid())
  userId             String
  title              String
  bucket             String
  durationMin        Int
  effort             String
  flexibility        String
  status             String
  preferredTimeOfDay String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model EnergySnapshot {
  id                String   @id @default(cuid())
  userId            String
  timestamp         DateTime
  circadianBaseline Int
  ultradianPhase    String
  compositeIndex    Int
  sleepPressure     Int
  redline           Boolean
  confidence        Float
  createdAt         DateTime @default(now())
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
